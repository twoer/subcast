{
  "manifest_version": 3,
  "name": "Subcast Live",
  "version": "0.1.0",
  "description": "Real-time subtitles for any web video using local AI models",
  "permissions": ["tabCapture", "activeTab", "storage"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"]
    }
  ],
  "action": {
    "default_title": "Subcast Live"
  },
  "icons": {}
}
