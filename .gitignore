# Dependencies
node_modules/
.pnpm-store/

# Nuxt build output
.nuxt/
.output/
dist/

# Tests / coverage
coverage/
.vitest-cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo

# Env
.env
.env.local
.env.*.local

# Local user-data caches (Subcast 运行时用 ~/.subcast，不会进 repo，但保险)
/tmp/
*.sqlite
*.sqlite-journal

# Local Claude Code config + early spec-kit drafts (contain absolute dev paths)
.claude/
archive/
dist-electron/
desktop-dist/
binaries/*/
.dev-userdata/

# Generated app icons (regenerated by `pnpm build:desktop:icons` from
# public/favicon.svg + assets/tray/trayTemplate.svg — deterministic,
# no need to commit the outputs).
assets/icon.png
assets/icon.icns
assets/icon.ico
# Tray dir: keep the SVG source (build input), ignore generated PNGs.
assets/tray/*
!assets/tray/trayTemplate.svg
docs/audits/

# Local sandboxes for one-off spikes / model downloads / scratch files —
# kept out of the repo so spike artifacts (often 10–100 MB) never sneak in.
.cache/

# AI agent working docs — internal task checklists ("For agentic workers:
# REQUIRED SUB-SKILL ...") and design specs written during development.
# Never referenced from any user-facing file (README / CONTRIBUTING /
# AGENTS). Kept locally for the maintainer, not published.
docs/superpowers/
# Sidecar scratch / runtime artifacts (Python __pycache__, etc.)
server/sidecars/__pycache__/

# Local tooling config (mcporter for autoglm-browser-agent, etc.) — machine-specific.
config/
